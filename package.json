{
  "name": "lorien-research",
  "private": true,
  "version": "1.0.7",
  "type": "module",
  "main": "dist-electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "server": "tsx watch server/index.ts",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "build:electron-dev": "tsup electron/main.ts electron/preload.ts --outDir dist-electron --format cjs --external electron",
    "dev:electron": "npm run build:electron-dev && concurrently \"vite\" \"tsx watch server/index.ts\" \"wait-on http://localhost:5173 && electron .\"",
    "build:electron": "npm run build && tsup electron/main.ts electron/preload.ts --outDir dist-electron --format cjs --external electron --clean",
    "package:mac": "npm run build:electron && electron-builder --mac",
    "package:win": "npm run build:electron && electron-builder --win"
  },
  "build": {
    "appId": "com.lorien.research",
    "productName": "Lorien Research",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "extraResources": [
      {
        "from": "dist",
        "to": "dist"
      },
      {
        "from": ".claude/skills/deep-research",
        "to": "skills",
        "filter": [
          "**/*"
        ]
      }
    ],
    "publish": {
      "provider": "github",
      "owner": "nic-seo",
      "repo": "lorien-research"
    },
    "artifactName": "lorien-research-${version}-${arch}.${ext}",
    "mac": {
      "target": ["dmg", "zip"],
      "category": "public.app-category.productivity"
    },
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "npmRebuild": false
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@tiptap/extension-placeholder": "^3.20.0",
    "@tiptap/pm": "^3.20.0",
    "@tiptap/react": "^3.20.0",
    "@tiptap/starter-kit": "^3.20.0",
    "@types/pouchdb": "^6.4.2",
    "dotenv": "^17.3.1",
    "electron-updater": "^6.8.3",
    "events": "^3.3.0",
    "express": "^5.2.1",
    "lucide-react": "^0.575.0",
    "marked": "^17.0.3",
    "pouchdb": "^9.0.0",
    "pouchdb-find": "^9.0.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.13.1",
    "tiptap-markdown": "^0.9.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/express": "^5.0.6",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^9.2.1",
    "electron": "^40.8.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "wait-on": "^9.0.4"
  }
}
